<Application
    x:Class="NeuralV.Windows.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="AppBackgroundBrush" Color="#0F1118" />
        <SolidColorBrush x:Key="AppSurfaceBrush" Color="#171A22" />
        <SolidColorBrush x:Key="AppSurfaceRaisedBrush" Color="#202534" />
        <SolidColorBrush x:Key="AppAccentBrush" Color="#7C6BFF" />
        <SolidColorBrush x:Key="AppAccentSoftBrush" Color="#2E3147" />
        <SolidColorBrush x:Key="AppOutlineBrush" Color="#39415A" />
        <SolidColorBrush x:Key="AppTextBrush" Color="#F5F7FF" />
        <SolidColorBrush x:Key="AppMutedTextBrush" Color="#B6BED8" />
        <SolidColorBrush x:Key="AppSuccessBrush" Color="#5CC18A" />
        <SolidColorBrush x:Key="AppWarningBrush" Color="#FFB861" />
        <SolidColorBrush x:Key="AppDangerBrush" Color="#FF7F96" />

        <CornerRadius x:Key="WindowCardCornerRadius">28</CornerRadius>
        <CornerRadius x:Key="SecondaryCardCornerRadius">22</CornerRadius>
        <CornerRadius x:Key="ChipCornerRadius">18</CornerRadius>
        <CornerRadius x:Key="FieldCornerRadius">20</CornerRadius>

        <Style x:Key="HeroTitleStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI Variable Display Semib" />
            <Setter Property="FontSize" Value="42" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{ThemeResource AppTextBrush}" />
            <Setter Property="TextWrapping" Value="WrapWholeWords" />
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI Variable Display" />
            <Setter Property="FontSize" Value="28" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{ThemeResource AppTextBrush}" />
        </Style>

        <Style x:Key="BodyTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI Variable Text" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="Foreground" Value="{ThemeResource AppMutedTextBrush}" />
            <Setter Property="TextWrapping" Value="WrapWholeWords" />
        </Style>

        <Style x:Key="NeuralVButtonStyle" TargetType="Button">
            <Setter Property="FontFamily" Value="Segoe UI Variable Text Semibold" />
            <Setter Property="CornerRadius" Value="20" />
            <Setter Property="Padding" Value="18,14" />
            <Setter Property="MinHeight" Value="54" />
            <Setter Property="MinWidth" Value="160" />
            <Setter Property="Background" Value="{ThemeResource AppAccentBrush}" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource NeuralVButtonStyle}">
            <Setter Property="Background" Value="{ThemeResource AppAccentSoftBrush}" />
            <Setter Property="Foreground" Value="{ThemeResource AppTextBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{ThemeResource AppOutlineBrush}" />
        </Style>

        <Style x:Key="FieldTextBoxStyle" TargetType="TextBox">
            <Setter Property="FontFamily" Value="Segoe UI Variable Text" />
            <Setter Property="CornerRadius" Value="20" />
            <Setter Property="Padding" Value="16,12" />
            <Setter Property="Background" Value="{ThemeResource AppSurfaceRaisedBrush}" />
            <Setter Property="Foreground" Value="{ThemeResource AppTextBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource AppOutlineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="FieldPasswordBoxStyle" TargetType="PasswordBox">
            <Setter Property="FontFamily" Value="Segoe UI Variable Text" />
            <Setter Property="CornerRadius" Value="20" />
            <Setter Property="Padding" Value="16,12" />
            <Setter Property="Background" Value="{ThemeResource AppSurfaceRaisedBrush}" />
            <Setter Property="Foreground" Value="{ThemeResource AppTextBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource AppOutlineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
    </Application.Resources>
</Application>
