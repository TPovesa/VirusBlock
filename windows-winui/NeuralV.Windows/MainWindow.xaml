<Window
    x:Class="NeuralV.Windows.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="NeuralV">

    <Grid x:Name="WindowRoot" Background="{ThemeResource AppBackgroundBrush}" Loaded="OnRootLoaded">
        <Grid>
            <Rectangle x:Name="BackdropGradient" />
            <Rectangle x:Name="FabricLayerA" Width="1600" Height="800" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-300,-160,0,0" Opacity="0.18" />
            <Rectangle x:Name="FabricLayerB" Width="1600" Height="820" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-120,-220,0" Opacity="0.14" />
            <Rectangle x:Name="FabricLayerC" Width="1600" Height="840" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,-220" Opacity="0.10" />
            <Ellipse x:Name="GlowA" Width="520" Height="520" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-120,-80,0,0" Opacity="0.28" />
            <Ellipse x:Name="GlowB" Width="620" Height="620" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-180,-180" Opacity="0.22" />
            <Ellipse x:Name="GlowC" Width="420" Height="420" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,-140" Opacity="0.16" />
        </Grid>

        <Grid x:Name="ShellFrame" Padding="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="RailColumn" Width="300" />
                <ColumnDefinition x:Name="GutterColumn" Width="20" />
                <ColumnDefinition x:Name="ContentColumn" Width="*" />
            </Grid.ColumnDefinitions>

            <Border x:Name="RailPanel" Grid.Column="0" Background="{ThemeResource AppSurfaceStrongBrush}" BorderBrush="{ThemeResource AppOutlineBrush}" BorderThickness="1" CornerRadius="24" Padding="18">
                <StackPanel>
                    <TextBlock Text="NeuralV" Foreground="{ThemeResource AppTextBrush}" FontSize="30" FontWeight="SemiBold" Margin="0,0,0,4" />
                    <TextBlock Text="Windows-клиент" Foreground="{ThemeResource AppMutedTextBrush}" Margin="0,0,0,16" />
                    <Border Background="{ThemeResource AppSecondaryContainerBrush}" BorderBrush="{ThemeResource AppOutlineBrush}" BorderThickness="1" CornerRadius="14" Padding="10,6" HorizontalAlignment="Left" Margin="0,0,0,12">
                        <TextBlock x:Name="RailBadgeText" Foreground="{ThemeResource AppTextBrush}" />
                    </Border>
                    <TextBlock x:Name="RailHeadlineText" Foreground="{ThemeResource AppTextBrush}" FontSize="28" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,0,0,8" />
                    <TextBlock x:Name="RailDescriptionText" Foreground="{ThemeResource AppMutedTextBrush}" TextWrapping="Wrap" Margin="0,0,0,16" />
                    <TextBlock x:Name="PaletteSourceLabel" Foreground="{ThemeResource AppMutedTextBrush}" TextWrapping="Wrap" Margin="0,0,0,10" />
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Border x:Name="PaletteSwatchPrimary" Width="40" Height="40" CornerRadius="12" Margin="0,0,8,0" />
                        <Border x:Name="PaletteSwatchSecondary" Width="40" Height="40" CornerRadius="12" Margin="0,0,8,0" />
                        <Border x:Name="PaletteSwatchTertiary" Width="40" Height="40" CornerRadius="12" />
                    </StackPanel>
                    <TextBlock x:Name="PaletteSeedLabel" Foreground="{ThemeResource AppSubtleTextBrush}" TextWrapping="Wrap" Margin="0,0,0,18" />
                    <TextBlock x:Name="RailUserNameText" Foreground="{ThemeResource AppTextBrush}" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,6" />
                    <TextBlock x:Name="RailUserMetaText" Foreground="{ThemeResource AppMutedTextBrush}" TextWrapping="Wrap" Margin="0,0,0,8" />
                    <Border Background="{ThemeResource AppSecondaryContainerBrush}" BorderBrush="{ThemeResource AppOutlineBrush}" BorderThickness="1" CornerRadius="14" Padding="10,6" HorizontalAlignment="Left">
                        <TextBlock x:Name="RailUserStateText" Foreground="{ThemeResource AppTextBrush}" />
                    </Border>
                </StackPanel>
            </Border>

            <Grid x:Name="ContentShell" Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid x:Name="HeaderMetaBar" Grid.Row="0" Margin="0,0,0,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="ThemeModeLabel" Grid.Column="0" Foreground="{ThemeResource AppTextBrush}" Margin="0,0,12,0" />
                    <TextBlock x:Name="PaletteModeHeaderLabel" Grid.Column="1" Foreground="{ThemeResource AppTextBrush}" Margin="0,0,12,0" />
                    <TextBlock x:Name="VersionLabel" Grid.Column="3" Foreground="{ThemeResource AppTextBrush}" />
                </Grid>

                <Border Grid.Row="1" Background="{ThemeResource AppSurfaceStrongBrush}" BorderBrush="{ThemeResource AppOutlineBrush}" BorderThickness="1" CornerRadius="24" Padding="20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid x:Name="AppNavigationBar" Grid.Row="0" Visibility="Collapsed" Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="HomeNavButton" Content="Обзор" Click="OnHomeClick" Margin="0,0,10,0" />
                                <Button x:Name="HistoryNavButton" Content="История" Click="OnHistoryClick" Margin="0,0,10,0" />
                                <Button x:Name="SettingsNavButton" Content="Настройки" Click="OnSettingsClick" />
                            </StackPanel>
                            <TextBlock x:Name="UserLabel" Grid.Column="1" Foreground="{ThemeResource AppTextBrush}" />
                        </Grid>

                        <Border x:Name="StatusBanner" Grid.Row="1" Visibility="Collapsed" Background="{ThemeResource AppSurfaceBrush}" BorderBrush="{ThemeResource AppOutlineBrush}" BorderThickness="1" CornerRadius="16" Padding="12" Margin="0,0,0,16">
                            <TextBlock x:Name="StatusBannerText" Foreground="{ThemeResource AppTextBrush}" TextWrapping="Wrap" />
                        </Border>

                        <Grid Grid.Row="2">
                            <StackPanel x:Name="SplashView" HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="520">
                                <Border x:Name="SplashHalo" Width="128" Height="128" CornerRadius="64" Background="{ThemeResource AppAccentSoftBrush}" HorizontalAlignment="Center" Margin="0,0,0,18">
                                    <Ellipse x:Name="SplashOrbitRing" Width="92" Height="92" Stroke="{ThemeResource AppAccentBrush}" StrokeThickness="2" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <TextBlock Text="Запускаем NeuralV" Foreground="{ThemeResource AppTextBrush}" FontSize="34" FontWeight="SemiBold" TextAlignment="Center" Margin="0,0,0,10" />
                                <TextBlock Text="Поднимаем палитру, сессию и основной экран." Foreground="{ThemeResource AppMutedTextBrush}" TextWrapping="Wrap" TextAlignment="Center" />
                            </StackPanel>

                            <StackPanel x:Name="WelcomeView" Visibility="Collapsed" MaxWidth="860">
                                <TextBlock Text="NeuralV для Windows" Foreground="{ThemeResource AppTextBrush}" FontSize="36" FontWeight="SemiBold" Margin="0,0,0,10" />
                                <TextBlock Text="Нативный клиент для входа, проверки, истории и обновления." Foreground="{ThemeResource AppMutedTextBrush}" TextWrapping="Wrap" Margin="0,0,0,18" />
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Войти в аккаунт" Click="OnShowLoginClick" Margin="0,0,12,0" />
                                    <Button Content="Создать аккаунт" Click="OnShowRegisterClick" />
                                </StackPanel>
                            </StackPanel>

                            <StackPanel x:Name="LoginView" Visibility="Collapsed" MaxWidth="720">
                                <TextBlock Text="Вход" Foreground="{ThemeResource AppTextBrush}" FontSize="32" FontWeight="SemiBold" Margin="0,0,0,10" />
                                <TextBox x:Name="LoginEmailBox" Margin="0,0,0,12" />
                                <PasswordBox x:Name="LoginPasswordBox" Margin="0,0,0,18" />
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Назад" Click="OnBackToWelcomeClick" Margin="0,0,12,0" />
                                    <Button Content="Продолжить" Click="OnStartLoginClick" />
                                </StackPanel>
                            </StackPanel>

                            <StackPanel x:Name="RegisterView" Visibility="Collapsed" MaxWidth="720">
                                <TextBlock Text="Регистрация" Foreground="{ThemeResource AppTextBrush}" FontSize="32" FontWeight="SemiBold" Margin="0,0,0,10" />
                                <TextBox x:Name="RegisterNameBox" Margin="0,0,0,12" />
                                <TextBox x:Name="RegisterEmailBox" Margin="0,0,0,12" />
                                <PasswordBox x:Name="RegisterPasswordBox" Margin="0,0,0,12" />
                                <PasswordBox x:Name="RegisterPasswordRepeatBox" Margin="0,0,0,18" />
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Назад" Click="OnBackToWelcomeClick" Margin="0,0,12,0" />
                                    <Button Content="Создать аккаунт" Click="OnStartRegisterClick" />
                                </StackPanel>
                            </StackPanel>

                            <StackPanel x:Name="CodeView" Visibility="Collapsed" MaxWidth="720">
                                <TextBlock Text="Подтверждение" Foreground="{ThemeResource AppTextBrush}" FontSize="32" FontWeight="SemiBold" Margin="0,0,0,10" />
                                <TextBlock x:Name="CodeHintText" Foreground="{ThemeResource AppMutedTextBrush}" TextWrapping="Wrap" Margin="0,0,0,18" />
                                <TextBox x:Name="VerificationCodeBox" Margin="0,0,0,18" />
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Назад" Click="OnBackFromCodeClick" Margin="0,0,12,0" />
                                    <Button Content="Войти" Click="OnVerifyCodeClick" />
                                </StackPanel>
                            </StackPanel>

                            <StackPanel x:Name="HomeView" Visibility="Collapsed" MaxWidth="920">
                                <TextBlock Text="Панель проверки" Foreground="{ThemeResource AppTextBrush}" FontSize="34" FontWeight="SemiBold" Margin="0,0,0,10" />
                                <TextBlock x:Name="HomeStatusText" Foreground="{ThemeResource AppMutedTextBrush}" TextWrapping="Wrap" Margin="0,0,0,18" />
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
                                    <Button x:Name="QuickScanButton" Content="Быстрая проверка" Click="OnQuickScanClick" Margin="0,0,12,0" />
                                    <Button x:Name="DeepScanButton" Content="Глубокая проверка" Click="OnDeepScanClick" />
                                </StackPanel>
                                <TextBlock x:Name="UpdateStatusText" Foreground="{ThemeResource AppMutedTextBrush}" TextWrapping="Wrap" Margin="0,0,0,8" />
                                <Button x:Name="UpdateButton" Content="Скачать обновление" Click="OnDownloadUpdateClick" Visibility="Collapsed" HorizontalAlignment="Left" Margin="0,0,0,18" />
                                <ListView x:Name="HomeTimelineList" SelectionMode="None" BorderThickness="0" Background="Transparent" />
                            </StackPanel>

                            <Grid x:Name="ScanView" Visibility="Collapsed">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="300" />
                                    <ColumnDefinition Width="20" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock x:Name="ScanPrimaryText" Foreground="{ThemeResource AppTextBrush}" FontSize="24" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,0,0,10" />
                                    <TextBlock x:Name="ScanSecondaryText" Foreground="{ThemeResource AppMutedTextBrush}" TextWrapping="Wrap" Margin="0,0,0,18" />
                                    <Button Content="Отменить проверку" Click="OnCancelScanClick" Margin="0,0,0,10" />
                                    <Button Content="Назад" Click="OnBackToHomeClick" />
                                </StackPanel>
                                <ListView x:Name="ScanTimelineList" Grid.Column="2" SelectionMode="None" BorderThickness="0" Background="Transparent" />
                            </Grid>

                            <StackPanel x:Name="HistoryView" Visibility="Collapsed">
                                <TextBlock Text="История" Foreground="{ThemeResource AppTextBrush}" FontSize="34" FontWeight="SemiBold" Margin="0,0,0,10" />
                                <ListView x:Name="HistoryList" SelectionMode="None" BorderThickness="0" Background="Transparent" />
                            </StackPanel>

                            <StackPanel x:Name="SettingsView" Visibility="Collapsed" MaxWidth="720">
                                <TextBlock Text="Настройки" Foreground="{ThemeResource AppTextBrush}" FontSize="34" FontWeight="SemiBold" Margin="0,0,0,10" />
                                <TextBlock x:Name="SettingsPaletteText" Foreground="{ThemeResource AppMutedTextBrush}" TextWrapping="Wrap" Margin="0,0,0,8" />
                                <TextBlock x:Name="SettingsVersionText" Foreground="{ThemeResource AppMutedTextBrush}" TextWrapping="Wrap" Margin="0,0,0,8" />
                                <TextBlock x:Name="SettingsSessionText" Foreground="{ThemeResource AppMutedTextBrush}" TextWrapping="Wrap" Margin="0,0,0,12" />
                                <Button Content="Выйти из аккаунта" Click="OnLogoutClick" HorizontalAlignment="Left" />
                            </StackPanel>
                        </Grid>

                        <Border x:Name="BusyOverlay" Grid.RowSpan="3" Background="{ThemeResource AppOverlayScrimBrush}" CornerRadius="24" Visibility="Collapsed">
                            <Grid>
                                <Border Background="{ThemeResource AppSurfaceBrush}" BorderBrush="{ThemeResource AppOutlineStrongBrush}" BorderThickness="1" CornerRadius="16" Padding="16" Width="300" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock x:Name="BusyText" Text="Загрузка" Foreground="{ThemeResource AppTextBrush}" TextWrapping="Wrap" TextAlignment="Center" />
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
