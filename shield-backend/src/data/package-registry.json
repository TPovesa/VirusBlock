{
  "packages": [
    {
      "name": "neuralv",
      "title": "NeuralV",
      "description": "Клиент защиты NeuralV для Windows и Linux.",
      "homepage": "https://sosiskibot.ru/neuralv/",
      "variants": [
        {
          "id": "windows-gui",
          "label": "Windows GUI",
          "os": "windows",
          "default": true,
          "install_strategy": "windows-portable-zip",
          "uninstall_strategy": "windows-remove-dir",
          "install_root": "%LOCALAPPDATA%/NeuralV",
          "source": {
            "type": "github-branch-manifest",
            "repo": "Perdonus/fatalerror",
            "branch": "windows-builds",
            "platform": "windows"
          }
        },
        {
          "id": "linux-gui",
          "label": "Linux GUI",
          "os": "linux",
          "default": false,
          "install_strategy": "linux-portable-tar",
          "uninstall_strategy": "linux-remove-dir",
          "install_root": "$HOME/.local/opt/NeuralV",
          "launcher_path": "NeuralV/bin/NeuralV",
          "source": {
            "type": "github-branch-manifest",
            "repo": "Perdonus/fatalerror",
            "branch": "linux-gui-builds",
            "platform": "linux"
          }
        },
        {
          "id": "linux-cli",
          "label": "Linux CLI",
          "os": "linux",
          "default": true,
          "install_strategy": "linux-cli-wrapper",
          "uninstall_strategy": "linux-cli-wrapper-remove",
          "install_root": "$HOME/.local/share/neuralv-shell",
          "binary_name": "neuralv-shell",
          "wrapper_name": "neuralv",
          "source": {
            "type": "github-branch-manifest",
            "repo": "Perdonus/fatalerror",
            "branch": "linux-cli-builds",
            "platform": "shell"
          }
        }
      ]
    },
    {
      "name": "nv",
      "title": "NV",
      "description": "Пакетный менеджер NeuralV.",
      "homepage": "https://sosiskibot.ru/neuralv/nv",
      "variants": [
        {
          "id": "nv-linux",
          "label": "NV Linux",
          "os": "linux",
          "default": true,
          "install_strategy": "unix-self-binary",
          "install_root": "$HOME/.local/bin",
          "binary_name": "nv",
          "source": {
            "type": "github-branch-manifest",
            "repo": "Perdonus/NV",
            "branch": "linux-builds",
            "platform": "nv-linux"
          }
        },
        {
          "id": "nv-windows",
          "label": "NV Windows",
          "os": "windows",
          "default": true,
          "install_strategy": "windows-self-binary",
          "install_root": "%LOCALAPPDATA%/NV",
          "binary_name": "nv.exe",
          "source": {
            "type": "github-branch-manifest",
            "repo": "Perdonus/NV",
            "branch": "windows-builds",
            "platform": "nv-windows"
          }
        }
      ]
    }
  ]
}
