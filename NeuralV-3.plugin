        "max_file_mb_text": "Макс. размер файла (MB)",
        "max_file_mb_sub": "Файлы больше этого размера не проверяются локально (1–50)",
        "no_reply": "⚠️ NeuralV: Ответь на файл или сообщение с кодом командой .vcheck",
        "no_content": "⚠️ NeuralV: В сообщении нет текста или кода для проверки.",
        "analyzing": "⌛ NeuralV: Проверяю код локально...",
        "download_error": "❗ NeuralV: Не удалось загрузить файл. Отправь его ещё раз.",
        "read_error": "❗ NeuralV: Не удалось прочитать файл. Попробуй отправить его ещё раз.",
        "too_big": "❗ NeuralV: Файл слишком большой (>{mb} MB).",
        "binary_file": "❗ NeuralV: Похоже, это не текстовый кодовый файл. Локальная проверка ждёт текст или код.",
        "unexpected": "❗ NeuralV: Не удалось завершить проверку. Попробуй ещё раз.",
        "report_header": "🛡 Отчёт проверки: {filename}\n\n",
        "report_footer": "\n\nИтоговая оценка: {icon} {word}",
        "cache_empty": "📂 NeuralV: История проверок пуста.",
        "cache_header": "📊 История проверки NeuralV:\n\n",
        "cache_row": "{icon} {name} — {word} ({age})\n",
        "age_min": "{n} мин. назад",
        "age_hour": "{n} ч. назад",
        "vinfo_usage": "⚠️ Укажи имя файла. Пример: .vinfo bot.py",
        "vinfo_not_found": "❗ NeuralV: Файл «{name}» не найден в истории.",
        "vinfo_expired": "⏳ NeuralV: Запись устарела. Перепроверь файл.",
        "vinfo_header": "🛡 Отчёт из кэша: {name}\n\n",
        "vinfo_footer": "\n\nИтоговая оценка: {icon} {word}",
        "vclear_done": "🧹 NeuralV: История очищена.",
        "vhelp_text": (
            "🛡 NeuralV — команды:\n\n"
            "• .vcheck — ответить на файл или текст с кодом для проверки\n"
            "• .vlist  — история последних проверок\n"
            "• .vinfo [имя] — полный отчёт из кэша\n"
            "• .vclear — очистить историю\n"
            "• .vhelp  — эта справка\n\n"
            "Проверка идёт полностью локально: без ИИ, без API и без внешних сервисов."
        ),
    }


class NeuralVPlugin(BasePlugin):
    def __init__(self):
        super().__init__()
        self.v_cache: Dict[str, Dict[str, Any]] = {}

    def on_plugin_load(self):
        self.add_on_send_message_hook()
        log("[NeuralV] loaded")

    def on_plugin_unload(self):
        self.v_cache.clear()
        log("[NeuralV] unloaded")

    def create_settings(self) -> List[Any]:
        s = get_localized_strings()
        return [
            Header(text=s["settings_header"]),
            Divider(text=s["settings_subtitle"]),
            Header(text=s["local_section"]),
            Input(
                key="max_file_mb",
                text=s["max_file_mb_text"],
                subtext=s["max_file_mb_sub"],
                default="10",
                icon="input_phone",
            ),
        ]

    def _s(self, key: str, **kwargs) -> str:
        template = get_localized_strings().get(key, key)
        try:
            return template.format(**kwargs) if kwargs else template
        except Exception:
            return template

    def _show_error(self, key: str, **kwargs):
        msg = self._s(key, **kwargs)
        run_on_ui_thread(lambda: BulletinHelper.show_error(msg))

    def _show_runtime_error(self, error: Exception):
        text = str(error or "").lower()
        if "не удалось загрузить файл" in text or "download" in text or "attach" in text:
            self._show_error("download_error")
        elif "decode" in text or "utf-" in text or "binary" in text:
            self._show_error("binary_file")
        elif "permission" in text or "read" in text or "open" in text:
            self._show_error("read_error")
        else:
            self._show_error("unexpected")

    def _show_status(self, verdict_word: str, verdict_icon: str):
        def inner():
            if verdict_word == "Опасно":
                BulletinHelper.show_error(f"{verdict_icon} {verdict_word}")
            elif verdict_word == "Осторожно":
                BulletinHelper.show_info(f"{verdict_icon} {verdict_word}")
            else:
                BulletinHelper.show_success(f"{verdict_icon} {verdict_word}")
        run_on_ui_thread(inner)

    def _get_max_bytes(self) -> int:
        try:
            mb = max(1, min(50, int(self.get_setting("max_file_mb", "10"))))
        except Exception:
            mb = 10
        return mb * 1024 * 1024

    def _send_msg(self, params: Any, text: str):
        try:
            send_message({"peer": params.peer, "message": text})
        except Exception as e:
            log(f"[NeuralV] _send_msg failed: {e}")

    def _store_report(self, filename: str, analysis: Dict[str, object]):
        self.v_cache[filename] = {
            "report": analysis["report"],
            "icon": analysis["icon"],
            "word": analysis["verdict"],
            "kind": analysis["kind_label"],
            "ts": time.time(),
        }

    def _send_report(self, params: Any, filename: str, analysis: Dict[str, object]):
        self._store_report(filename, analysis)
        word = str(analysis["verdict"])
        icon = str(analysis["icon"])
        report = str(analysis["report"])
        header = self._s("report_header", filename=filename)
        footer = self._s("report_footer", icon=icon, word=word)
        self._send_msg(params, header + report + footer)
        self._show_status(word, icon)

    def _send_vlist(self, params: Any):
        if not self.v_cache:
            self._send_msg(params, self._s("cache_empty"))
            return
        now = time.time()
        text = self._s("cache_header")
        for name, entry in self.v_cache.items():
            age_min = int((now - float(entry["ts"])) / 60)
            age = self._s("age_min", n=age_min) if age_min < 60 else self._s("age_hour", n=age_min // 60)
            text += self._s("cache_row", icon=entry["icon"], name=name, word=entry["word"], age=age)
        self._send_msg(params, text)

    def _send_vinfo(self, params: Any, args: str):
        name = args.strip()
        if not name:
            self._send_msg(params, self._s("vinfo_usage"))
            return
        entry = self.v_cache.get(name)
        if not entry:
            self._send_msg(params, self._s("vinfo_not_found", name=name))
            return
        if time.time() - float(entry["ts"]) > CACHE_TTL:
            self._send_msg(params, self._s("vinfo_expired"))
            return
        header = self._s("vinfo_header", name=name)
        footer = self._s("vinfo_footer", icon=entry["icon"], word=entry["word"])
        self._send_msg(params, header + str(entry["report"]) + footer)

    def _send_vclear(self, params: Any):
        self.v_cache.clear()
        self._send_msg(params, self._s("vclear_done"))

    def _send_vhelp(self, params: Any):
        self._send_msg(params, self._s("vhelp_text"))

    def _normalize_path_candidate(self, value: Any) -> str:
        if value is None:
            return ""
        try:
            if hasattr(value, "getAbsolutePath"):
                value = value.getAbsolutePath()
            elif hasattr(value, "toString"):
                value = value.toString()
        except Exception:
            pass
        try:
            path = str(value).strip()
        except Exception:
            return ""
        if not path or path.lower() == "null":
            return ""
        return path

    def _collect_document_paths(self, document: Any, reply_msg: Any = None) -> List[str]:
        candidates: List[str] = []
        seen = set()

        def add(value: Any):
            path = self._normalize_path_candidate(value)
            if not path or path in seen:
                return
            if os.path.isabs(path) or os.path.exists(path):
                seen.add(path)
                candidates.append(path)

        try:
            loader = get_file_loader()
        except Exception:
            loader = None

        if loader is not None:
            for force in (True, False):
                try:
                    add(loader.getPathToAttach(document, force))
                except Exception:
                    pass

        for attr in ("path", "localPath", "attachPath", "filePath", "local_path", "file_path"):
            try:
                add(getattr(document, attr, None))
            except Exception:
                pass

        if reply_msg is not None:
            for holder in (reply_msg, getattr(reply_msg, "messageOwner", None)):
                if holder is None:
                    continue
                for attr in ("attachPath", "path", "localPath", "filePath", "local_path", "file_path"):
                    try:
                        add(getattr(holder, attr, None))
                    except Exception:
                        pass

        return candidates

    def _pick_ready_document_path(self, document: Any, reply_msg: Any = None, timeout_sec: int = 30) -> str:
        loader = get_file_loader()

        def find_ready_path() -> str:
            for path in self._collect_document_paths(document, reply_msg):
                try:
                    if os.path.isfile(path) and os.path.getsize(path) > 0:
                        return path
                except Exception:
                    continue
            return ""

        path = find_ready_path()
        if path:
            return path

        try:
            loader.loadFile(document, "neuralv", FileLoader.PRIORITY_HIGH, 1)
        except Exception:
            pass

        for _ in range(timeout_sec):
            path = find_ready_path()
            if path:
                return path
            time.sleep(1)

        raise RuntimeError(self._s("download_error"))

    def _read_document_bytes(self, document: Any, reply_msg: Any = None) -> bytes:
        path = self._pick_ready_document_path(document, reply_msg)
        with open(path, "rb") as fh:
            return fh.read()

    def _analyze_bytes(self, params: Any, filename: str, raw: bytes):
        max_bytes = self._get_max_bytes()
        if len(raw) > max_bytes:
            self._show_error("too_big", mb=max_bytes // (1024 * 1024))
            return
        if looks_binary(raw, filename):
            self._show_error("binary_file")
            return
        text = raw.decode("utf-8", errors="ignore")
        if not text.strip():
            self._show_error("no_content")
            return
        analysis = LocalAnalyzer(text, filename).analyze()
        self._send_report(params, filename, analysis)

    def _analyze_file_task(self, params: Any, document: Any, reply_msg: Any = None):
        try:
            filename = getattr(document, "file_name_fixed", None) or f"file_{int(time.time())}.txt"
            raw = self._read_document_bytes(document, reply_msg)
            self._analyze_bytes(params, filename, raw)
        except RuntimeError as e:
            log(f"[NeuralV] _analyze_file_task: {traceback.format_exc()}")
            if str(e) == self._s("download_error"):
                self._show_error("download_error")
            else:
                self._show_runtime_error(e)
        except Exception as e:
            log(f"[NeuralV] _analyze_file_task: {traceback.format_exc()}")
            self._show_runtime_error(e)

    def _analyze_text_task(self, params: Any, text: str, filename: str):
        try:
            max_bytes = self._get_max_bytes()
            if len(text.encode("utf-8", "ignore")) > max_bytes:
                self._show_error("too_big", mb=max_bytes // (1024 * 1024))
                return
            analysis = LocalAnalyzer(text, filename).analyze()
            self._send_report(params, filename, analysis)
        except Exception as e:
            log(f"[NeuralV] _analyze_text_task: {traceback.format_exc()}")
            self._show_runtime_error(e)

    def on_send_message_hook(self, account: int, params: Any) -> HookResult:
        if not hasattr(params, "message") or not isinstance(params.message, str):
            return HookResult()

        msg = params.message.strip()
        cmd = msg.lower()

        if cmd == VLIST_CMD:
            run_on_queue(lambda: self._send_vlist(params))
            return HookResult(strategy=HookStrategy.CANCEL)

        if cmd == VCLEAR_CMD:
            run_on_queue(lambda: self._send_vclear(params))
            return HookResult(strategy=HookStrategy.CANCEL)

        if cmd == VHELP_CMD:
            run_on_queue(lambda: self._send_vhelp(params))
            return HookResult(strategy=HookStrategy.CANCEL)

        if cmd.startswith(VINFO_CMD):
            args = msg[len(VINFO_CMD):].strip()
            run_on_queue(lambda: self._send_vinfo(params, args))
            return HookResult(strategy=HookStrategy.CANCEL)

        if cmd != VCHECK_CMD:
            return HookResult()

        if not hasattr(params, "replyToMsg") or not params.replyToMsg:
            self._show_error("no_reply")
            return HookResult(strategy=HookStrategy.CANCEL)

        reply_msg = params.replyToMsg
        document = None
        try:
            document = MessageObject.getDocument(reply_msg.messageOwner)
        except Exception:
            document = None

        run_on_ui_thread(lambda: BulletinHelper.show_info(self._s("analyzing")))

        if document:
            run_on_queue(lambda: self._analyze_file_task(params, document, reply_msg))
        else:
            try:
                reply_text = (reply_msg.messageOwner.message or "").strip()
            except Exception:
                reply_text = ""
            if not reply_text:
                self._show_error("no_content")
                return HookResult(strategy=HookStrategy.CANCEL)
            filename = f"snippet_{int(time.time())}.txt"
            run_on_queue(lambda: self._analyze_text_task(params, reply_text, filename))

        return HookResult(strategy=HookStrategy.CANCEL)
