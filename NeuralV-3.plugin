VCHECK_CMD = ".vcheck"
VLIST_CMD = ".vlist"
VINFO_CMD = ".vinfo"
VCLEAR_CMD = ".vclear"
VHELP_CMD = ".vhelp"
CACHE_TTL = 3600
TEXT_SAMPLE_SIZE = 8192
TEXT_EXTENSIONS = {
    ".py",
    ".plugin",
    ".txt",
    ".json",
    ".js",
    ".ts",
    ".jsx",
    ".tsx",
    ".yaml",
    ".yml",
    ".ini",
    ".cfg",
    ".conf",
    ".toml",
    ".env",
    ".md",
    ".csv",
    ".xml",
    ".html",
    ".css",
    ".sql",
    ".sh",
}
VERDICT_ICONS = {
    "Безопасно": "✅",
    "Осторожно": "⚠️",
    "Опасно": "🚫",
}
SEVERITY_LABELS = {
    "low": "Низко",
    "medium": "Средне",
    "high": "Высоко",
    "critical": "Критично",
}
SEVERITY_SCORES = {
    "low": 1,
    "medium": 3,
    "high": 6,
    "critical": 10,
}
TOKEN_RE = re.compile(r"\b\d{8,10}:[A-Za-z0-9_-]{30,}\b")
OPENAI_KEY_RE = re.compile(r"\bsk-[A-Za-z0-9]{20,}\b", re.IGNORECASE)
URL_RE = re.compile(r"https?://[^\s'\"<>]+", re.IGNORECASE)
BASE64_BLOB_RE = re.compile(r"[A-Za-z0-9+/]{180,}={0,2}")
SENSITIVE_NAME_RE = re.compile(r"(token|session|cookie|passwd|password|secret|api[_-]?key|authorization)", re.IGNORECASE)


class SyntaxCollector(ast.NodeVisitor):
    def __init__(self):
        self.imports: Set[str] = set()
        self.calls: List[str] = []
        self.class_bases: List[str] = []
        self.class_names: List[str] = []
        self.functions: Set[str] = set()
        self.strings: List[str] = []
        self.names: Set[str] = set()
        self.has_shell_true = False

    def visit_Import(self, node):
        for alias in node.names:
            self.imports.add(alias.name)
        self.generic_visit(node)

    def visit_ImportFrom(self, node):
        module = node.module or ""
        for alias in node.names:
            full = f"{module}.{alias.name}" if module else alias.name
            self.imports.add(full)
        self.generic_visit(node)

    def visit_ClassDef(self, node):
        self.class_names.append(node.name)
        for base in node.bases:
            name = dotted_name(base)
            if name:
                self.class_bases.append(name)
        self.generic_visit(node)

    def visit_FunctionDef(self, node):
        self.functions.add(node.name)
        self.generic_visit(node)

    def visit_AsyncFunctionDef(self, node):
        self.functions.add(node.name)
        self.generic_visit(node)

    def visit_Call(self, node):
        name = dotted_name(node.func)
        if name:
            self.calls.append(name)
        for kw in node.keywords:
            if kw.arg == "shell" and isinstance(kw.value, ast.Constant) and kw.value.value is True:
                self.has_shell_true = True
        self.generic_visit(node)

    def visit_Name(self, node):
        self.names.add(node.id)
        self.generic_visit(node)

    def visit_Constant(self, node):
        if isinstance(node.value, str):
            self.strings.append(node.value)
        self.generic_visit(node)


class Finding:
    __slots__ = ("key", "severity", "title", "summary", "terms", "evidence")

    def __init__(self, key: str, severity: str, title: str, summary: str, terms: Iterable[str], evidence: List[str]):
        self.key = key
        self.severity = severity
        self.title = title
        self.summary = summary
        self.terms = list(terms)
        self.evidence = evidence


class LocalAnalyzer:
    def __init__(self, source: str, filename: str):
        self.source = normalize_text(source)
        self.filename = filename or "snippet.txt"
        self.lines = self.source.splitlines() or [self.source]
        self.lower = self.source.lower()
        self.ext = detect_extension(self.filename)
        self.tree = None
        self.collector = SyntaxCollector()
        try:
            self.tree = ast.parse(self.source)
            self.collector.visit(self.tree)
        except Exception:
            self.tree = None
        self.imports_lower = {item.lower() for item in self.collector.imports}
        self.calls_lower = [item.lower() for item in self.collector.calls]
        self.functions_lower = {item.lower() for item in self.collector.functions}
        self.class_bases_lower = [item.lower() for item in self.collector.class_bases]
        self.class_names_lower = [item.lower() for item in self.collector.class_names]
        self.strings_lower = [item.lower() for item in self.collector.strings[:400]]
        self.seed = hashlib.sha256((self.filename + "\n" + self.source).encode("utf-8", "ignore")).hexdigest()

    def analyze(self) -> Dict[str, object]:
        kind, kind_label, mismatch_note = self._classify_kind()
        findings = self._collect_findings(mismatch_note)
        score = sum(SEVERITY_SCORES[item.severity] for item in findings)
        verdict = self._pick_verdict(score, findings)
        icon = VERDICT_ICONS[verdict]
        report = self._build_report(kind_label, mismatch_note, findings, verdict)
        return {
            "filename": self.filename,
            "kind": kind,
            "kind_label": kind_label,
            "mismatch_note": mismatch_note,
            "findings": findings,
            "score": score,
            "verdict": verdict,
            "icon": icon,
            "report": report,
        }

    def _classify_kind(self):
        extera_score = 0
        hikka_score = 0

        if contains_import(self.imports_lower, "base_plugin"):
            extera_score += 5
        if any(base.endswith("baseplugin") for base in self.class_bases_lower):
            extera_score += 5
        if "create_settings" in self.functions_lower:
            extera_score += 2
        if "on_send_message_hook" in self.functions_lower:
            extera_score += 3
        if "hookresult" in self.lower or "hookstrategy" in self.lower:
            extera_score += 2
        if "__min_version__" in self.lower:
            extera_score += 2
        if "ui.settings" in self.lower or "ui.bulletin" in self.lower:
            extera_score += 2

        if "@loader.tds" in self.lower:
            hikka_score += 4
        if contains_import(self.imports_lower, "loader"):
            hikka_score += 3
        if "loader.moduleconfig" in self.lower:
            hikka_score += 4
        if "loader.configvalue" in self.lower:
            hikka_score += 3
        if "utils.answer" in self.lower:
            hikka_score += 2
        if any("loader.module" in base for base in self.class_bases_lower):
            hikka_score += 5
        if any(name.endswith("mod") for name in self.class_names_lower):
            hikka_score += 1
        if "@loader.command" in self.lower:
            hikka_score += 3

        if extera_score >= max(5, hikka_score + 2):
            kind = "extera"
            label = "плагин ExteraGram"
        elif hikka_score >= max(5, extera_score + 2):
            kind = "hikka"
            label = "модуль Hikka/Heroku"
        elif self._looks_like_python():
            kind = "python"
            label = "обычный Python-скрипт"
        else:
            kind = "text"
            label = "текстовый файл без явной структуры модуля"

        mismatch_note = ""
        if self.ext == ".plugin" and kind != "extera":
            mismatch_note = (
                "Файл назван как Extera-плагин, но по структуре больше похож "
                f"на {label}. Простым переименованием такой файл за плагин маскировать можно."
            )
        elif self.ext == ".py" and kind == "extera":
            mismatch_note = (
                "Файл имеет обычное расширение .py, но по внутренним маркерам это именно Extera-плагин. "
                "Если его выдают за другой формат, это стоит проверять вручную."
            )
        elif self.ext == ".plugin" and kind == "text":
            mismatch_note = "Файл назван как plugin, но внутри не видно ни структуры Extera, ни нормального Python-модуля."
        return kind, label, mismatch_note

    def _looks_like_python(self) -> bool:
        if self.tree is not None:
            return True
        markers = ["def ", "class ", "import ", "from ", "return ", "async def "]
        return sum(1 for item in markers if item in self.lower) >= 2

    def _collect_findings(self, mismatch_note: str) -> List[Finding]:
        findings: List[Finding] = []
        add = findings.append

        dynamic_terms = []
        if contains_call(self.calls_lower, "exec") or "exec(" in self.lower:
            dynamic_terms.append("exec")
        if contains_call(self.calls_lower, "eval") or "eval(" in self.lower:
            dynamic_terms.append("eval")
        if "exec(compile(" in self.lower.replace(" ", ""):
            dynamic_terms.append("exec(compile")
        if dynamic_terms:
            severity = "critical" if "exec(compile" in self.lower.replace(" ", "") else "high"
            add(self._make_finding(
                "dynamic_exec",
                severity,
                "Динамическое выполнение кода",
                "Код сам собирает и запускает выражения на лету. Это один из самых опасных паттернов для модулей и плагинов.",
                dynamic_terms,
            ))

        obfuscation_terms = []
        for term in ["base64", "marshal", "zlib", "binascii", "codecs.decode"]:
            if term in self.lower:
                obfuscation_terms.append(term)
        if BASE64_BLOB_RE.search(self.source):
            obfuscation_terms.append("encoded_blob")
        if obfuscation_terms:
            severity = "high" if dynamic_terms else "medium"
            add(self._make_finding(
                "obfuscation",
                severity,
                "Признаки сокрытия логики",
                "Внутри есть кодеки, упаковка или крупные закодированные блоки. Такое часто используют, чтобы спрятать реальное поведение.",
                obfuscation_terms,
            ))

        shell_terms = []
        for term in [
            "os.system",
            "subprocess.run",
            "subprocess.popen",
            "subprocess.call",
            "subprocess.check_output",
            "asyncio.create_subprocess_shell",
        ]:
            if contains_call(self.calls_lower, term):
                shell_terms.append(term)
        if self.collector.has_shell_true:
            shell_terms.append("shell=True")
        if shell_terms:
            severity = "critical" if self.collector.has_shell_true else "high"
            add(self._make_finding(
                "shell_exec",
                severity,
                "Запуск системных команд",
                "Модуль умеет выходить в shell или дергать системные процессы. Для чат-расширений это зона повышенного риска.",
                shell_terms,
            ))

        network_terms = []
        for term in [
            "requests.get",
            "requests.post",
            "httpx.get",
            "httpx.post",
            "aiohttp.clientsession",
            "socket.socket",
            "websockets.connect",
            "urllib.request.urlopen",
        ]:
            if contains_call(self.calls_lower, term) or term in self.lower:
                network_terms.append(term)
        urls = URL_RE.findall(self.source)[:6]
        if urls:
            network_terms.extend(urls[:2])
        if network_terms:
            add(self._make_finding(
                "network",
                "low",
                "Сетевые обращения",
                "Код ходит во внешнюю сеть. Само по себе это не делает его вредоносным, но такой трафик нужно понимать по назначению.",
                network_terms,
            ))

        remote_exec = False
        if network_terms and (dynamic_terms or "importlib" in self.lower or "runpy" in self.lower):
            if any(fragment in self.lower for fragment in ["requests.get(", "httpx.get(", "urlopen(", "download_media("]):
                remote_exec = True
        if remote_exec:
            add(self._make_finding(
                "remote_exec",
                "critical",
                "Похоже на догрузку и запуск удалённого кода",
                "Есть связка из сетевой загрузки и последующего исполнения. Это уже не просто сетевой модуль, а крайне рискованный сценарий.",
                ["requests.get", "httpx.get", "urlopen", "exec", "importlib"],
            ))

        secret_terms = []
        if "os.getenv" in self.lower or "os.environ" in self.lower:
            secret_terms.extend(["os.getenv", "os.environ"])
        if TOKEN_RE.search(self.source):
            secret_terms.append("telegram_token")
        if OPENAI_KEY_RE.search(self.source):
            secret_terms.append("api_key_literal")
        if any(SENSITIVE_NAME_RE.search(text) for text in self.strings_lower[:80]):
            secret_terms.append("sensitive_names")
        if secret_terms:
            severity = "medium" if network_terms else "low"
            add(self._make_finding(
                "secret_access",
                severity,
                "Доступ к чувствительным данным",
                "Код работает с токенами, сессионными строками или секретами окружения. Без понятной причины это настораживает.",
                secret_terms,
            ))

        surveillance_terms = []
        for term in ["pynput", "keyboard", "pyautogui", "imagegrab", "pil.imagegrab", "mss", "cv2.videocapture", "clipboard"]:
            if term in self.lower:
                surveillance_terms.append(term)
        if surveillance_terms:
            add(self._make_finding(
                "surveillance",
                "high",
                "Слежение за вводом или экраном",
                "В коде видны импорты и вызовы, связанные с клавиатурой, буфером обмена, скриншотами или захватом экрана.",
                surveillance_terms,
            ))

        persistence_terms = []
        for term in ["winreg", "runonce", "software\\microsoft\\windows\\currentversion\\run", "cron", "schtasks", "startup", ".desktop"]:
            if term in self.lower:
                persistence_terms.append(term)
        if persistence_terms:
            add(self._make_finding(
                "persistence",
                "high",
                "Признаки персистентности",
                "Код пытается закрепиться в системе и переживать перезапуск. Для обычного плагина это лишний и опасный слой.",
                persistence_terms,
            ))

        privilege_terms = []
        for term in ["shell.executew", "runas", "isuseranadmin", "ctypes.windll", "sudo ", "pkexec"]:
            if term in self.lower:
                privilege_terms.append(term.strip())
        if privilege_terms:
            add(self._make_finding(
                "privilege",
                "high",
                "Попытка получить повышенные права",
                "В коде есть паттерны, связанные с запуском от администратора или с прямой работой через системные API.",
                privilege_terms,
            ))

        destructive_terms = []
        for term in ["shutil.rmtree", "os.remove", "os.unlink", ".unlink(", ".rmdir(", "os.walk", "path.unlink"]:
            if term in self.lower:
                destructive_terms.append(term)
        if destructive_terms:
            severity = "high" if "shutil.rmtree" in destructive_terms else "medium"
            add(self._make_finding(
                "destructive_fs",
                severity,
                "Агрессивные операции с файлами",
                "Есть удаление файлов или каталогов. В обычных утилитах это бывает, но без явного контекста такой код лучше не запускать вслепую.",
                destructive_terms,
            ))

        if mismatch_note:
            add(self._make_finding(
                "format_mismatch",
                "medium",
                "Формат файла не совпадает с содержимым",
                mismatch_note,
                [self.ext or "unknown_ext"],
            ))

        unique: Dict[str, Finding] = {}
        for item in findings:
            prev = unique.get(item.key)
            if not prev or SEVERITY_SCORES[item.severity] > SEVERITY_SCORES[prev.severity]:
                unique[item.key] = item
        return sorted(unique.values(), key=lambda item: (-SEVERITY_SCORES[item.severity], item.title))

    def _make_finding(self, key: str, severity: str, title: str, summary: str, terms: Iterable[str]) -> Finding:
        evidence = []
        lowered_terms = [str(term).lower() for term in terms if term]
        for term in lowered_terms:
            evidence.extend(find_evidence(self.lines, term))
            if len(evidence) >= 2:
                break
        deduped = []
        seen = set()
        for item in evidence:
            if item not in seen:
                deduped.append(item)
                seen.add(item)
        return Finding(key, severity, title, summary, lowered_terms, deduped[:2])

    def _pick_verdict(self, score: int, findings: List[Finding]) -> str:
        severities = {item.severity for item in findings}
        if "critical" in severities or score >= 12:
            return "Опасно"
        if "high" in severities or score >= 5:
            return "Осторожно"
        return "Безопасно"

    def _build_report(self, kind_label: str, mismatch_note: str, findings: List[Finding], verdict: str) -> str:
        purpose = self._compose_purpose(kind_label, findings)
        checked = self._compose_checked()
        findings_text = self._compose_findings(findings)
        conclusion = self._compose_conclusion(verdict, findings, mismatch_note)
        sections = [
            "1. Тип и назначение\n" + purpose,
            "2. Что проверено\n" + checked,
            "3. Что найдено\n" + findings_text,
            "4. Что важно учесть\n" + conclusion,
            "5. Итог\n" + verdict,
        ]
        return "\n\n".join(sections).strip()

    def _compose_purpose(self, kind_label: str, findings: List[Finding]) -> str:
        if kind_label == "плагин ExteraGram":
            first = pick_variant([
                "Похоже на плагин ExteraGram: внутри есть характерная базовая обвязка, хук обработки сообщений и блок локальных настроек.",
                "Код выглядит как плагин ExteraGram: он подключается к клиенту, ловит сообщения и добавляет собственные действия поверх чата.",
            ], self.seed + "purpose-extera")
        elif kind_label == "модуль Hikka/Heroku":
            first = pick_variant([
                "Похоже на модуль Hikka/Heroku: видны loader-команды, конфиг модуля и типичная структура чат-расширения.",
                "Код выглядит как модуль Hikka/Heroku: он объявляет команды, использует loader и встраивается в существующий клиентский сценарий.",
            ], self.seed + "purpose-hikka")
        elif kind_label == "обычный Python-скрипт":
            first = pick_variant([
                "Это обычный Python-скрипт без явной привязки к ExteraGram или Hikka/Heroku.",
                "По структуре это скорее самостоятельный Python-файл, а не готовый чат-плагин под конкретный клиент.",
            ], self.seed + "purpose-python")
        else:
            first = "Внутри нет устойчивой структуры полноценного плагина. Это просто текстовый файл или сильно урезанный фрагмент кода."

        if any(item.key in {"dynamic_exec", "remote_exec", "surveillance"} for item in findings):
            second = "При этом в логике уже есть поведение, которое выходит далеко за рамки обычной вспомогательной автоматизации."
        elif any(item.key in {"network", "secret_access", "destructive_fs"} for item in findings):
            second = "Внутри есть прикладные действия с сетью, файлами или чувствительными данными, поэтому код нельзя считать совсем безобидным без ручной проверки."
        else:
            second = "По явным маркерам код похож на обычную служебную логику и не выглядит как попытка скрытно выполнить что-то постороннее."

        return first + " " + second

    def _compose_checked(self) -> str:
        return pick_variant([
            "Проверил запуск системных команд, сетевые вызовы, операции с файлами, работу с секретами, признаки обфускации и попытки догружать код снаружи.",
            "Проверка прошла по ключевым зонам риска: shell-команды, внешняя сеть, чувствительные данные, скрытие логики, удаление файлов и признаки закрепления в системе.",
            "Разобрал импортную карту, вызовы функций, строковые литералы и характерные сигнатуры: от shell и сети до токенов, обфускации и персистентности.",
        ], self.seed + "checked")

    def _compose_findings(self, findings: List[Finding]) -> str:
        if not findings:
            return pick_variant([
                "Явных опасных паттернов не видно. Сетевых догрузок, shell-команд, скрытого запуска кода и агрессивных операций с файлами в явном виде нет.",
                "На уровне сигнатур код выглядит спокойно: нет явных попыток тянуть и исполнять удалённый код, ломиться в shell или прятать реальную логику через упаковку.",
            ], self.seed + "clean")

        rows = []
        for item in findings[:6]:
            row = f"- {SEVERITY_LABELS[item.severity]}: {item.title}. {item.summary}"
            if item.evidence:
                row += " Примеры: " + "; ".join(item.evidence)
            rows.append(row)
        return "\n".join(rows)

    def _compose_conclusion(self, verdict: str, findings: List[Finding], mismatch_note: str) -> str:
        if verdict == "Опасно":
            text = pick_variant([
                "Набор признаков уже слишком тяжёлый для безопасного плагина. Такой код лучше не запускать без полной ручной разборки и изоляции.",
                "Картина больше похожа на рискованный или вредоносный сценарий, чем на обычный модуль. Без песочницы и ручного аудита запускать это не стоит.",
            ], self.seed + "conclusion-danger")
        elif verdict == "Осторожно":
            text = pick_variant([
                "Здесь нет однозначного приговора по одному сигналу, но связка найденных паттернов требует ручной проверки и понимания контекста.",
                "Код нельзя назвать заведомо вредоносным по одному признаку, но и доверять ему вслепую уже нельзя. Нужна ручная проверка перед запуском.",
            ], self.seed + "conclusion-warn")
        else:
            text = pick_variant([
                "По текущим сигнатурам это выглядит как спокойный модуль без грубых признаков вредоносной активности.",
                "На уровне статического разбора код выглядит адекватно: явных попыток скрыть опасное поведение или навредить системе не видно.",
            ], self.seed + "conclusion-safe")

        if mismatch_note:
            text += " Отдельно настораживает несовпадение имени файла и его реальной структуры."
        return text


def normalize_text(text: str) -> str:
    return (text or "").replace("\r\n", "\n").replace("\r", "\n")


def detect_extension(filename: str) -> str:
    filename = (filename or "").lower().strip()
    if "." not in filename:
        return ""
    return "." + filename.rsplit(".", 1)[-1]


def dotted_name(node) -> str:
    if isinstance(node, ast.Name):
        return node.id
    if isinstance(node, ast.Attribute):
        base = dotted_name(node.value)
        return f"{base}.{node.attr}" if base else node.attr
    if isinstance(node, ast.Call):
        return dotted_name(node.func)
    return ""


def contains_import(imports_lower: Set[str], fragment: str) -> bool:
    fragment = fragment.lower()
    return any(fragment == item or item.endswith("." + fragment) or fragment in item for item in imports_lower)


def contains_call(calls_lower: List[str], fragment: str) -> bool:
    fragment = fragment.lower()
    return any(call == fragment or call.endswith("." + fragment) or fragment in call for call in calls_lower)


def pick_variant(options: List[str], seed: str) -> str:
    if not options:
        return ""
    digest = hashlib.sha256(seed.encode("utf-8", "ignore")).hexdigest()
    index = int(digest[:8], 16) % len(options)
    return options[index]


def find_evidence(lines: List[str], term: str) -> List[str]:
    term = (term or "").lower().strip()
    if not term:
        return []
    found = []
    for idx, line in enumerate(lines, 1):
        if term in line.lower():
            compact = " ".join(line.strip().split())
            if compact:
                found.append(f"строка {idx}: {compact[:140]}")
            if len(found) >= 2:
                break
    return found


def looks_binary(data: bytes, filename: str) -> bool:
    if not data:
        return False
    ext = detect_extension(filename)
    if ext and ext in TEXT_EXTENSIONS:
        return False
    if b"\x00" in data[:TEXT_SAMPLE_SIZE]:
        return True
    sample = data[:TEXT_SAMPLE_SIZE]
    printable = 0
    for byte in sample:
        if byte in (9, 10, 13) or 32 <= byte <= 126:
            printable += 1
    return printable / max(1, len(sample)) < 0.78


